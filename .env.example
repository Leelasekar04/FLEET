# =============================================================
# Fleet Expense & Batta Management System — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# =============================================================
# SERVER
# =============================================================
PORT=4000
NODE_ENV=development

# =============================================================
# WhatsApp Business Cloud API (Meta Developer Console)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# =============================================================
WHATSAPP_TOKEN=your_whatsapp_permanent_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_string
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_BASE=https://graph.facebook.com

# =============================================================
# Google Gemini AI API
# https://aistudio.google.com/app/apikey
# =============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# =============================================================
# Supabase (Database + Storage)
# https://supabase.com/dashboard/project/_/settings/api
# =============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=fleet-receipts

# =============================================================
# JWT (for dashboard API authentication)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================
JWT_SECRET=your_jwt_secret_key_minimum_64_chars
JWT_EXPIRES_IN=7d

# =============================================================
# Frontend (Next.js)
# =============================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME="Fleet Manager"
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# =============================================================
# Database (Direct PostgreSQL — for local dev)
# =============================================================
DATABASE_URL=postgresql://fleet_user:fleet_pass@localhost:5432/fleet_db

# =============================================================
# Optional — Sentry (Error Monitoring)
# =============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
